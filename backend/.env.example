# Copy to .env (or set these in your host's dashboard). None are required for
# local development — the app falls back to a local SQLite file.

# PostgreSQL / Supabase connection string. When set, ALL data (users, deals,
# comparables, market cache) lives here instead of SQLite.
# Supabase: Project Settings -> Database -> Connection string (URI).
# DATABASE_URL=postgresql://postgres.abcxyz:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Signing secret for auth tokens. REQUIRED in production (a random per-process
# secret is used if unset, which invalidates all sessions on restart).
# ARDHI_JWT_SECRET=change-me-to-a-long-random-string

# Enables the AI narrative layer. Without it, that feature is simply hidden.
# ANTHROPIC_API_KEY=sk-ant-...
# ARDHI_NARRATIVE_MODEL=claude-opus-4-8

# Where SQLite files live when DATABASE_URL is unset (defaults to backend/data,
# or /data inside the Docker image).
# ARDHI_DATA_DIR=/data
